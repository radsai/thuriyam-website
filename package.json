{
  "name": "dashboard-ui-new",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ngrok": "concurrently -n dev,ngrok -c blue,magenta \"vite --strictPort\" \"ngrok http 5173\"",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "preview:ngrok": "npm run build && concurrently -n preview,ngrok -c blue,magenta \"vite preview --port 5173\" \"ngrok http 5173\"",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
